# AdminFrontend – all env in .env only

VITE_ENV=development

# Admin Backend (Port 8002) – Candidates, Positions, Credits, etc.
VITE_API_BASE_URL=http://localhost:8002
VITE_ADMIN_API_URL=http://localhost:8002

# Auth + Superadmin (Port 8001) – Login, Refresh, Settings, Credits
VITE_AUTH_API_URL=http://localhost:8001
VITE_API_REFRESH_URL=http://localhost:8001/auth-session/refresh
VITE_SUPERADMIN_API_URL=http://localhost:8001

# Candidate Backend (Port 8003) – Resume processing
VITE_CANDIDATE_API_URL=http://localhost:8003

# AI Service (Port 9000) – Streaming AI: interview questions, JD generator, skills, resume ATS
VITE_AI_SERVICE_URL=http://127.0.0.1:9000
VITE_AI_ASSISTANT_URL=http://localhost:8002/ai-assistant

